      "Id": "d79be395b85c4a65a7c7827e3e8adc71",
      "Name": "stress",
      "ConnectionName": "LocalDB",
      "Database": "GridletSample",
      "Sql": "SET NOCOUNT ON;\n\nWITH Numbers AS\n(\n    SELECT TOP (500000)\n        ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS RowNumber\n    FROM sys.all_objects a\n    CROSS JOIN sys.all_objects b\n)\nSELECT\n    RowNumber,\n    HASHBYTES(\n        'SHA2_512',\n        REPLICATE(CONVERT(varchar(max), RowNumber), 100)\n    ) AS CalculatedValue,\n    REPLICATE(N'X', 500) AS SampleData\nFROM Numbers\nORDER BY RowNumber;",
      "UpdatedAtUtc": "2026-07-11T10:46:12.9833594+00:00"
    }
  ],
